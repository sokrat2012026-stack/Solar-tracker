/*------------------------------------------------------------------------------
  БЛОК 13: ПЕРИОДИЧЕСКИЕ ЗАДАЧИ (BlynkTimer)
  ==============================================================================
  - sendHeartbeat(): отправка "PING" в STM32 каждые 5 секунд
  - checkSTM32Connection(): проверка связи со STM32 каждые 10 секунд
------------------------------------------------------------------------------*/
// Отправка heartbeat для поддержания связи
void sendHeartbeat()
{
  sendCommandToSTM32("PING");
}
// Проверка связи со STM32
void checkSTM32Connection()
{
  // Если нет данных от STM32 более 10 секунд
  if(millis() - lastSTM32Heartbeat > 10000)
  {
    if(stm32Connected)
    {
      stm32Connected = false;
      Blynk.virtualWrite(V_COMM_MODE, 0);  // Сигнализируем о потере связи
      Serial.println("[ERROR] STM32 connection lost!");
      Blynk.logEvent("stm32_lost", "STM32 communication lost");
      // Отправляем Telegram о потере связи
      if(WiFi.status() == WL_CONNECTED)
      {
        sendTelegramAlert(6, -1);  // Код 6 = потеря связи
      }
    }
  }
}
/*------------------------------------------------------------------------------
  БЛОК 14: ФУНКЦИЯ SETUP()
  ==============================================================================
  Выполняется один раз при включении питания.
  Инициализирует UART, Wi-Fi, Blynk, Telegram.
------------------------------------------------------------------------------*/
void setup()
{
  // ----- 1. ИНИЦИАЛИЗАЦИЯ ПОСЛЕДОВАТЕЛЬНОГО ПОРТА (отладка) -----
  Serial.begin(115200);
  Serial.println("\n[ESP32] Solar Tracker Starting...");
  // ----- 2. ИНИЦИАЛИЗАЦИЯ UART ДЛЯ СВЯЗИ СО STM32 -----
  STM32_SERIAL.begin(STM32_BAUD, SERIAL_8N1, STM32_RX_PIN, STM32_TX_PIN);
  Serial.println("[UART] STM32 UART initialized at 115200 baud");
  // ----- 3. ПОДКЛЮЧЕНИЕ К Wi-Fi -----
  Serial.print("[WiFi] Connecting to ");
  Serial.print(ssid);
  WiFi.begin(ssid, pass);
  int attempts = 0;
  while(WiFi.status() != WL_CONNECTED && attempts < 40)  // Таймаут 20 секунд
  {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  if(WiFi.status() == WL_CONNECTED)
  {
    Serial.println("\n[WiFi] Connected!");
    Serial.print("[WiFi] IP address: ");
    Serial.println(WiFi.localIP());
  }
  else
  {
    Serial.println("\n[WiFi] Connection failed!");
  }
  // ----- 4. НАСТРОЙКА TELEGRAM (HTTPS без проверки сертификата) -----
  securedClient.setInsecure();  // Отключаем проверку SSL (упрощённо)
  // ----- 5. ПОДКЛЮЧЕНИЕ К BLYNK -----
  Serial.println("[Blynk] Connecting...");
  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();
  // ----- 6. НАСТРОЙКА ТАЙМЕРОВ -----
  timer.setInterval(5000L, sendHeartbeat);        // Heartbeat каждые 5 секунд
  timer.setInterval(10000L, checkSTM32Connection); // Проверка связи каждые 10 сек
  // ----- 7. ФИНАЛЬНАЯ НАСТРОЙКА -----
  lastSTM32Heartbeat = millis();
  Serial.println("[ESP32] Setup complete, entering main loop");
}
/*------------------------------------------------------------------------------
  БЛОК 15: ФУНКЦИЯ LOOP()
------------------------------------------------------------------------------*/
void loop()
{
  Blynk.run();      // Обработка входящих событий Blynk
  timer.run();      // Выполнение периодических задач
  // ----- ЧТЕНИЕ ДАННЫХ ОТ STM32 -----
  while(STM32_SERIAL.available())
  {
    char c = STM32_SERIAL.read();
    if(c == '<')
    {
      stm32Data = "";           // Начинаем новый пакет
    }
    else if(c == '>')
    {
      parseSTM32Data(stm32Data); // Пакет завершён - парсим
      stm32Data = "";
    }
    else
    {
      stm32Data += c;           // Добавляем символ в буфер
    }
  }
  delay(10);  // Небольшая задержка для снижения нагрузки
}
