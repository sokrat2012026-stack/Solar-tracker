  (Согласно блок-схеме алгоритма)
------------------------------------------------------------------------------*/
typedef enum {
  STATE_INIT = 0,      // 0: Начальная инициализация, проверка датчиков
  STATE_AUTO,          // 1: Автоматическое слежение за солнцем
  STATE_MANUAL,        // 2: Ручной режим (команды из Blynk)
  STATE_NIGHT,         // 3: Ночной режим (панель в безопасном положении)
  STATE_PARKING,       // 4: Аварийная парковка (движение в горизонталь)
  STATE_PARKED         // 5: Панель запаркована, трекинг заблокирован
} SystemState_t;
/*------------------------------------------------------------------------------
  БЛОК 4: ПЕРЕЧИСЛЕНИЕ КОДОВ АВАРИЙ
  (Для отправки в Blynk и Telegram)
------------------------------------------------------------------------------*/
typedef enum {
  ALARM_NONE = 0,          // 0: Аварий нет
  ALARM_WIND_HIGH = 1,     // 1: Ветер > 15 м/с
  ALARM_BATTERY_LOW = 2,   // 2: Напряжение АКБ < 21 В
  ALARM_PANEL_OVERHEAT = 3,// 3: Температура панели > 75°C
  ALARM_BOX_OVERHEAT = 4,  // 4: Температура шкафа > 50°C
  ALARM_MOTOR_OVERLOAD = 5,// 5: Ток двигателя > 15 А
  ALARM_STM32_ESP_LOST = 6,// 6: Потеря связи с ESP32 (>10 секунд)
  ALARM_SENSOR_ERROR = 7   // 7: Датчик не отвечает
} AlarmCode_t;
/*------------------------------------------------------------------------------
  БЛОК 5: СТРУКТУРА ДАННЫХ С ВСЕХ ДАТЧИКОВ
  (Полностью соответствует структурной схеме)
------------------------------------------------------------------------------*/
typedef struct {
  // ----- ЭЛЕКТРИЧЕСКИЕ ПАРАМЕТРЫ (INA219) -----
  float voltage_panel_v;      // Напряжение солнечной панели (0-26 В)
  float current_panel_a;      // Ток солнечной панели (0-3.2 А)
  float power_panel_w;        // Мощность = U * I (Вт)
  float voltage_battery_v;    // Напряжение аккумулятора 24 В
  float current_motor_a;      // Ток потребления двигателей (защита)
  
  // ----- ДАТЧИКИ ПОЛОЖЕНИЯ (AS5600 магнитные энкодеры) -----
  float azimuth_deg;          // Угол азимута (0-360°)
  float elevation_deg;        // Угол места (-90° до +90°)
  
  // ----- МЕТЕОДАННЫЕ (WF105 анемометр) -----
  float wind_speed_mps;       // Скорость ветра (0-30 м/с)
  
  // ----- ДАТЧИКИ ТЕМПЕРАТУРЫ (DS18B20 1-Wire) -----
  float temp_panel_c;         // Температура солнечной панели
  float temp_box_c;           // Температура шкафа управления
  float temp_inverter_c;      // Температура инвертора (опционально)
  
  // ----- ДАТЧИКИ СЛЕЖЕНИЯ ЗА СОЛНЦЕМ (2 фотодиода) -----
  uint16_t light_left;        // Левый датчик (ADC 0-4095)
  uint16_t light_right;       // Правый датчик (ADC 0-4095)
  
  // ----- КОНЦЕВЫЕ ВЫКЛЮЧАТЕЛИ (защита актуаторов) -----
  uint8_t limit_az_min;       // Концевик минимума азимута
  uint8_t limit_az_max;       // Концевик максимума азимута
  uint8_t limit_el_min;       // Концевик минимума угла места
  uint8_t limit_el_max;       // Концевик максимума угла места
  
  // ----- СТАТИСТИКА -----
  float energy_today_wh;      // Выработка за сегодня (Вт·ч)
  uint16_t parking_count;     // Счётчик аварийных парковок
} SensorData_t;
/*------------------------------------------------------------------------------
  БЛОК 6: ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ
------------------------------------------------------------------------------*/
static SystemState_t systemState = STATE_INIT;   // Текущее состояние системы
static AlarmCode_t currentAlarm = ALARM_NONE;    // Текущий код аварии
static uint32_t lastCycleTime = 0;               // Время последнего цикла
static uint32_t lastUARTSendTime = 0;            // Время последней отправки
static uint32_t lastLCDUpdateTime = 0;           // Время последнего обновления LCD
static uint32_t lastEnergyCalcTime = 0;          // Время последнего расчёта энергии
static uint8_t rxBuffer[64];                     // Буфер приёма от ESP32
static uint8_t rxIndex = 0;                      // Индекс в буфере
static uint32_t lastCommandTime = 0;             // Время последней команды от ESP32
static SensorData_t sensors = {0};               // Все данные с датчиков
static float energy_accumulator = 0.0f;          // Аккумулятор энергии (Вт·ч)
// Флаги для ручного управления (из Blynk)
static uint8_t manual_az_cmd = 0;   // 0=нет, 1=влево, 2=вправо
static uint8_t manual_el_cmd = 0;   // 0=нет, 1=вниз, 2=вверх
/*------------------------------------------------------------------------------
  БЛОК 7: АДРЕСА ДАТЧИКОВ И ПОРОГОВЫЕ ЗНАЧЕНИЯ
------------------------------------------------------------------------------*/
// I2C адреса для AS5600 (можно менять перемычками на плате)
#define AS5600_ADDR_AZ     0x36  // Энкодер азимута
#define AS5600_ADDR_EL     0x37  // Энкодер угла места
// I2C адреса для INA219 (задаются перемычками A0, A1)
#define INA219_ADDR_PANEL  0x40  // Монитор солнечной панели
#define INA219_ADDR_BATTERY 0x41 // Монитор аккумулятора
#define INA219_ADDR_MOTOR  0x44  // Монитор тока двигателей
// Идентификаторы датчиков DS18B20 (уникальные 64-битные коды)
#define DS18B20_PANEL      0     // Датчик на панели
#define DS18B20_BOX        1     // Датчик в шкафу
#define DS18B20_INVERTER   2     // Датчик инвертора
// Каналы АЦП (12-бит, 0-4095)
#define ADC_CH_LIGHT_LEFT  0     // Левый фотодиод
#define ADC_CH_LIGHT_RIGHT 1     // Правый фотодиод
#define ADC_CH_WIND        2     // Анемометр WF105 (0-5В -> 0-30 м/с)
// ПОРОГОВЫЕ ЗНАЧЕНИЯ ДЛЯ АВАРИЙ (согласно документации)
#define WIND_ALARM_THRESHOLD    15.0f   // Ветер > 15 м/с - парковка
#define BATTERY_MIN_VOLTAGE     21.0f   // АКБ 24В разряжен (<21В)
#define TEMP_PANEL_MAX          75.0f   // Панель перегрета (>75°C)
#define TEMP_BOX_MAX            50.0f   // Шкаф перегрет (>50°C)
#define MOTOR_MAX_CURRENT       15.0f   // Перегрузка двигателя (>15А)
// Параметры слежения
#define TRACKING_DEADBAND       50      // Мёртвая зона (ADC отсчёты)
#define PWM_AUTO_SPEED          50      // 50% скорости в авторежиме
#define PWM_PARKING_SPEED       80      // 80% скорости при парковке
#define PWM_MANUAL_SPEED        70      // 70% скорости в ручном режиме
